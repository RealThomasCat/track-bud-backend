# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
DATABASE_URL="YOUR_DATABASE_URL"

# ---- Redis ----
REDIS_URL="YOUR_REDIS_URL"
CACHE_ENABLED=true

# ---- Auth ----
JWT_SECRET="YOUR_JWT_SECRET"
JWT_EXPIRES_IN="1h"

# ---- Gemini ----
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ---- Frontend ----
FRONTEND_URL="http://localhost:3000"