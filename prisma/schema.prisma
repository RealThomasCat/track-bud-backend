// --------------------------
// Prisma Configuration
// --------------------------

generator client {
  // Generates the JS/TS Prisma client we use in our code
  provider = "prisma-client-js"
}

datasource db {
  // We're using PostgreSQL
  provider = "postgresql"
  // Reads from the DATABASE_URL and DIRECT_URL variables in .env
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

// --------------------------
// Enums
// --------------------------

enum TransactionKind {
  income
  expense
}

enum MonthlyReviewStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  INSUFFICIENT_DATA
}

enum DataQualityLevel {
  LOW
  MEDIUM
  HIGH
}

// --------------------------
// Models (Tables)
// --------------------------

// User deletion is intentionally not exposed through the API.
// onDelete: Restrict protects financial records from accidental user deletion.
model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  password        String
  defaultCurrency String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallets        Wallet[]
  categories     Category[]
  transactions   Transaction[]
  monthlyReviews MonthlyReview[]
}

// TODO: Add PostgreSQL partial unique index in a manual migration:
// CREATE UNIQUE INDEX uq_wallet_one_default_per_user
// ON "Wallet" ("userId")
// WHERE "isDefault" = true;
model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String   @default("Main Wallet")
  isDefault Boolean  @default(false)
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign key relation to User with Restrict on delete to prevent orphaned wallets if user is deleted
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  // Enforce unique wallet names per user
  @@unique([userId, name], map: "uq_wallet_user_id_name")
  // Allows Transaction(userId, walletId) to reference Wallet(userId, id).
  // To be able to use composite FK (userId, walletId) in Transaction model, we need to enforce uniqueness on (userId, id) in Wallet.
  @@unique([userId, id], map: "uq_wallet_user_id_id")
}

model Category {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String
  isDefault  Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([userId, name], map: "uq_category_user_id_name")
  // Allows Transaction(userId, categoryId) to reference Category(userId, id).
  // To be able to use composite FK (userId, categoryId) in Transaction model, we need to enforce uniqueness on (userId, id) in Category.
  @@unique([userId, id], map: "uq_category_user_id_id")
  // Speeds up finding user's active/archived categories
  @@index([userId, isArchived], map: "idx_categories_user_archived")
}

model Transaction {
  id         Int             @id @default(autoincrement())
  userId     Int
  walletId   Int
  categoryId Int
  kind       TransactionKind
  amount     Decimal         @db.Decimal(14, 2)
  occurredAt DateTime
  note       String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // Foreign key relations with Restrict on delete to prevent orphaned transactions if user/wallet/category is deleted
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  // Composite FK guarantees the wallet belongs to the same user as the transaction.
  wallet   Wallet   @relation(fields: [userId, walletId], references: [userId, id], onDelete: Restrict)
  // Composite FK guarantees the category belongs to the same user as the transaction.
  category Category @relation(fields: [userId, categoryId], references: [userId, id], onDelete: Restrict)

  // Speeds up queries for user's transactions and date range
  @@index([userId, occurredAt], map: "idx_transactions_user_occurred_at")
  // Speeds up queries for user's transactions filtered by kind and date range
  @@index([userId, kind, occurredAt], map: "idx_transactions_user_kind_occurred_at")
  // Speeds up queries for user's transactions filtered by category and date range
  @@index([userId, categoryId, occurredAt], map: "idx_transactions_user_category_occurred_at")
}

model MonthlyReview {
  id               Int                 @id @default(autoincrement())
  userId           Int
  // Tracks the lifecycle of the async monthly review job.
  status           MonthlyReviewStatus @default(PENDING)
  periodStart      DateTime
  periodEnd        DateTime
  // Previous (of review month) completed month range used for deterministic comparison metrics.
  comparisonStart  DateTime?
  comparisonEnd    DateTime?
  title            String?
  // Simple quality flag based on transaction count and income/expense coverage.
  // Indicates how reliable the review is based on available transaction coverage for the month.
  dataQualityLevel DataQualityLevel?
  transactionCount Int                 @default(0)
  // Stores the final structured review JSON after Zod validation.
  result           Json?
  // Safe failure message for the client when worker fails.
  errorMessage     String?
  // BullMQ job id for debugging only (Redis/logs). This is not treated as source of truth. (Not for CRUD in DB)
  jobId            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  completedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Prevents duplicate monthly reviews for the same user and calendar month.
  @@unique([userId, periodStart, periodEnd], map: "uq_monthly_review_user_period")
  // Speeds up finding active/in-progress review records for a user.
  @@index([userId, status], map: "idx_monthly_review_user_status")
  // Speeds up lookup for the current target month review.
  @@index([userId, periodStart, periodEnd], map: "idx_monthly_review_user_period")
}
