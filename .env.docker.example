# ---- PostgreSQL ----
POSTGRES_USER=trackbud
POSTGRES_PASSWORD=trackbud_password
POSTGRES_DB=track_bud
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Backend ----
BACKEND_PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://trackbud:trackbud_password@postgres:5432/track_bud?schema=public
REDIS_URL=redis://redis:6379
CACHE_ENABLED=true

# ---- Auth ----
JWT_SECRET=replace_with_local_jwt_secret
JWT_EXPIRES_IN=1h

# ---- Gemini ----
GEMINI_API_KEY=replace_with_local_gemini_key

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000